generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum useCase {
  coding
  school
  content
  research
  customer_support
  general_chat
  image_generation
}

model Audit {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  tools               Json
  teamSize            Int
  useCase             useCase  @default(coding)
  shareId             String   @unique @default(uuid())
  results             Json
  totalMonthlySavings Int
  totalAnnualSavings  Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  leads               Lead[]
}

model Lead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  company   String?
  role      String?
  teamSize  Int?
  auditId   String   @db.ObjectId
  audit     Audit    @relation(fields: [auditId], references: [id])
  createdAt DateTime @default(now())
}
